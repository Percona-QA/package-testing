pipeline {
    agent none

    parameters {
        string(name: 'PS_VERSION', defaultValue: '8.0.46-38')
        string(name: 'PS_REVISION', defaultValue: 'c643a1242d8')
        string(name: 'TAG', defaultValue: '8.0.46-38-1')
        choice(name: 'REPO', choices: ['testing', 'main'])
    }

    stages {

        stage('Prepare') {
            agent { label 'docker' }

            steps {
                script {
                    currentBuild.displayName = "#${BUILD_NUMBER}-${PS_VERSION}-${PS_REVISION}"
                    currentBuild.description = TAG
                }
            }
        }

        stage('Validation') {

            failFast false

            parallel {

                stage('AMD') {

                    agent { label 'docker' }

                    stages {

                        stage('Download Image') {
                            steps {
                                withCredentials([
                                    usernamePassword(
                                        credentialsId: 'PS_PRIVATE_REPO_ACCESS',
                                        usernameVariable: 'USERNAME',
                                        passwordVariable: 'PASSWORD'
                                    )
                                ]) {
                                    script {

                                        def url

                                        if (REPO == "testing") {
                                            url = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/qa-test/ps-gated-${PS_VERSION}/percona-server-${PS_VERSION}-1.docker.tar"
                                        } else {
                                            url = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/ps-57-eol/tarballs/Percona-Server-${PS_VERSION}/percona-server-${PS_VERSION}-1.docker.tar"
                                        }

                                        sh """
                                            rm -f *.docker.tar
                                            wget -q ${url}
                                            sudo docker load -i percona-server-${PS_VERSION}-1.docker.tar
                                        """
                                    }
                                }
                            }
                        }

                        stage('Run Trivy') {
                            steps {
                                sh '''
                                    # install trivy
                                    ...
                                    trivy image percona/percona-server:${TAG}
                                '''
                            }
                        }

                        stage('Run Tests') {
                            steps {
                                sh '''
                                    git clone https://github.com/Percona-QA/package-testing.git --depth 1
                                    cd package-testing/docker-image-tests/ps
                                    pip3 install --user -r requirements.txt
                                    ./run.sh
                                '''
                            }
                        }
                    }

                    post {
                        always {
                            junit '**/*junit.xml'
                            junit 'package-testing/docker-image-tests/ps/report.xml'
                        }
                    }
                }

                stage('ARM') {

                    agent { label 'docker-32gb-aarch64' }

                    stages {

                        stage('Download Image') {
                            steps {
                                withCredentials([
                                    usernamePassword(
                                        credentialsId: 'PS_PRIVATE_REPO_ACCESS',
                                        usernameVariable: 'USERNAME',
                                        passwordVariable: 'PASSWORD'
                                    )
                                ]) {
                                    script {

                                        def url

                                        if (REPO == "testing") {
                                            url = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/qa-test/ps-gated-${PS_VERSION}/percona-server-${PS_VERSION}-1.docker.tar"
                                        } else {
                                            url = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/ps-57-eol/tarballs/Percona-Server-${PS_VERSION}/percona-server-${PS_VERSION}-1.docker.tar"
                                        }

                                        sh """
                                            rm -f *.docker.tar
                                            wget -q ${url}
                                            sudo docker load -i percona-server-${PS_VERSION}-1.docker.tar
                                        """
                                    }
                                }
                            }
                        }

                        stage('Run Trivy') {
                            steps {
                                sh '''
                                    # install ARM trivy
                                    ...
                                    trivy image percona/percona-server:${TAG}
                                '''
                            }
                        }

                        stage('Run Tests') {
                            steps {
                                sh '''
                                    git clone https://github.com/Percona-QA/package-testing.git --depth 1
                                    cd package-testing/docker-image-tests/ps
                                    pip3 install --user -r requirements.txt
                                    ./run.sh
                                '''
                            }
                        }
                    }

                    post {
                        always {
                            junit '**/*junit.xml'
                            junit 'package-testing/docker-image-tests/ps/report.xml'
                        }
                    }
                }

            }
        }
    }
}
