pipeline {
    agent none

    parameters {
        string(name: 'UPSTREAM_VERSION', defaultValue: '5.7.44', description: 'Only upstream version')
        string(name: 'PS_VERSION', defaultValue: '49', description: 'Percona version')
        string(name: 'PXC_REVISION', defaultValue: '38d2944', description: 'Git revision')
        string(name: 'PXC_PKG_VERSION', defaultValue: '2', description: 'Package version')
        string(name: 'TAG', defaultValue: '5.7.44-31.65.2', description: 'Docker tag')
        string(name: 'PXC_WSREP_VERSION', defaultValue: '31.65', description: 'WSREP version')
        string(name: 'PXC_PXB_VERSION', defaultValue: '2.4.29', description: 'PXB version')
        choice(name: 'REPO', choices: ['testing', 'main'], description: 'Repository')
    }

    stages {

        stage('Prepare') {
            agent { label 'docker' }
            steps {
                script {
                    currentBuild.displayName = "#${BUILD_NUMBER}-${UPSTREAM_VERSION}-${PXC_REVISION}-${REPO}"
                    currentBuild.description = "${TAG}"
                }
            }
        }

        stage('Validation') {
            failFast false

            parallel {

                stage('Run Trivy Analyzer') {
                    agent { label 'docker' }

                    steps {
                        withCredentials([
                            usernamePassword(
                                credentialsId: 'PS_PRIVATE_REPO_ACCESS',
                                usernameVariable: 'USERNAME',
                                passwordVariable: 'PASSWORD'
                            )
                        ]) {

                            script {
                                def dockerTarURL

                                if (REPO == 'testing') {
                                    dockerTarURL = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/qa-test/pxc-gated-${UPSTREAM_VERSION}.${PXC_PKG_VERSION}/percona-xtradb-cluster-${UPSTREAM_VERSION}-${PXC_WSREP_VERSION}-${PXC_PKG_VERSION}.docker.tar"
                                } else {
                                    dockerTarURL = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/pxc-57-eol/tarballs/Percona-XtraDB-Cluster-${UPSTREAM_VERSION}/percona-xtradb-cluster-${UPSTREAM_VERSION}-${PXC_WSREP_VERSION}-${PXC_PKG_VERSION}.docker.tar"
                                }

                                sh """
                                    rm -f *.docker.tar
                                    wget -q ${dockerTarURL}
                                    sudo docker load -i percona-xtradb-cluster-${UPSTREAM_VERSION}-${PXC_WSREP_VERSION}-${PXC_PKG_VERSION}.docker.tar
                                """
                            }

                            sh """
                                sudo yum install -y wget git

                                TRIVY_VERSION=0.69.3
                                ARCH=\$(uname -m)

                                if [[ "\$ARCH" == "aarch64" ]]; then
                                    ARCH_NAME=ARM64
                                    TRIVY_CHECKSUM=7e3924a974e912e57b4a99f65ece7931f8079584dae12eb7845024f97087bdfd
                                else
                                    ARCH_NAME=64bit
                                    TRIVY_CHECKSUM=1816b632dfe529869c740c0913e36bd1629cb7688bd5634f4a858c1d57c88b75
                                fi

                                wget -q https://github.com/aquasecurity/trivy/releases/download/v\${TRIVY_VERSION}/trivy_\${TRIVY_VERSION}_Linux-\${ARCH_NAME}.tar.gz
                                echo "\${TRIVY_CHECKSUM}  trivy_\${TRIVY_VERSION}_Linux-\${ARCH_NAME}.tar.gz" | sha256sum -c -
                                sudo tar zxf trivy_\${TRIVY_VERSION}_Linux-\${ARCH_NAME}.tar.gz -C /usr/local/bin/

                                wget -q https://raw.githubusercontent.com/aquasecurity/trivy/v\${TRIVY_VERSION}/contrib/junit.tpl

                                trivy image \
                                  --severity HIGH,CRITICAL \
                                  --ignore-unfixed \
                                  --timeout 10m \
                                  percona/percona-xtradb-cluster:${TAG}

                                trivy image \
                                  --format template \
                                  --template @junit.tpl \
                                  -o trivy-high-junit.xml \
                                  --severity HIGH,CRITICAL \
                                  --ignore-unfixed \
                                  --timeout 10m \
                                  --exit-code 1 \
                                  percona/percona-xtradb-cluster:${TAG}
                            """
                        }
                    }

                    post {
                        always {
                            junit testResults: 'trivy-*.xml',
                                  allowEmptyResults: true,
                                  keepLongStdio: true,
                                  skipPublishingChecks: true
                        }
                    }
                }

                stage('Run Tests') {
                    agent { label 'docker' }

                    steps {
                        withCredentials([
                            usernamePassword(
                                credentialsId: 'PS_PRIVATE_REPO_ACCESS',
                                usernameVariable: 'USERNAME',
                                passwordVariable: 'PASSWORD'
                            )
                        ]) {

                            script {
                                def dockerTarURL

                                if (REPO == 'testing') {
                                    dockerTarURL = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/qa-test/pxc-gated-${UPSTREAM_VERSION}.${PXC_PKG_VERSION}/percona-xtradb-cluster-${UPSTREAM_VERSION}-${PXC_WSREP_VERSION}-${PXC_PKG_VERSION}.docker.tar"
                                } else {
                                    dockerTarURL = "https://repo.percona.com/private/${USERNAME}-${PASSWORD}/pxc-57-eol/tarballs/Percona-XtraDB-Cluster-${UPSTREAM_VERSION}/percona-xtradb-cluster-${UPSTREAM_VERSION}-${PXC_WSREP_VERSION}-${PXC_PKG_VERSION}.docker.tar"
                                }

                                sh """
                                    rm -f *.docker.tar
                                    wget -q ${dockerTarURL}
                                    sudo docker load -i percona-xtradb-cluster-${UPSTREAM_VERSION}-${PXC_WSREP_VERSION}-${PXC_PKG_VERSION}.docker.tar
                                """
                            }

                            sh '''
                                echo "echo never > /sys/kernel/mm/transparent_hugepage/enabled" > disable_thp.sh
                                echo "echo never > /sys/kernel/mm/transparent_hugepage/defrag" >> disable_thp.sh
                                chmod +x disable_thp.sh
                                sudo ./disable_thp.sh

                                export PATH=${PATH}:~/.local/bin

                                sudo yum install -y python3 python3-pip

                                rm -rf package-testing
                                git clone -b fix-pxc-eol-par https://github.com/kaushikpuneet07/package-testing.git --depth 1

                                cd package-testing/docker-image-tests/pxc-eol

                                pip3 install --user -r requirements.txt

                                ./run.sh
                            '''
                        }
                    }

                    post {
                        always {
                            junit 'package-testing/docker-image-tests/pxc-eol/report.xml'
                        }
                    }
                }
            }
        }
    }
}
